# Environment Variables for Fusion Model API
# Copy this file to .env and fill in actual values

# ==================== Server Configuration ====================
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ==================== Model Configuration ====================
MODEL_DIR=notebooks/MODELS
CONFIG_FILE=fusion_model_config.json

# ==================== CORS Configuration ====================
# For development, use *
# For production, specify allowed domains
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# ==================== Security ====================
SECRET_KEY=your-secret-key-here-change-in-production
API_KEY_REQUIRED=false
API_KEY=your-api-key-here

# ==================== Logging ====================
LOG_LEVEL=info
LOG_FILE=logs/fusion_api.log

# ==================== Database (Optional) ====================
DATABASE_URL=sqlite:///./fusion_db.db

# ==================== Monitoring ====================
SENTRY_DSN=
PROMETHEUS_ENABLED=false

# ==================== Cloud Platforms ====================
# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=

# Azure
AZURE_STORAGE_CONNECTION_STRING=
